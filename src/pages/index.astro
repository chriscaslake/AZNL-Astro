---
const year = new Date().getFullYear();
---

<html lang="en">
	
  <head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>AZNL | Modern Web Solutions</title>

    <link rel="stylesheet" href="/src/styles/global.css" />
	</head>

  <body class="bg-slate-50 text-slate-900 scroll-smooth">
    <nav
      class="fixed w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-200"
    >
      <div
        class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center"
      >
        <span class="text-xl font-bold tracking-tight text-brand-dark"
          >AZ<span class="text-brand-primary">NL</span></span
        >
        <div class="space-x-8 hidden md:block text-sm font-medium">
          <a href="#services" class="hover:text-brand-primary transition"
            >Services</a
          >
          <a href="#story" class="hover:text-brand-primary transition"
            >Our Story</a
          >
          <a
            href="#contact"
            class="px-4 py-2 bg-brand-dark text-white rounded-lg hover:bg-brand-primary transition"
            >Get Started</a
          >
        </div>
      </div>
    </nav>

    <!--  -->
    <header class="pt-32 pb-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h1
          class="text-5xl md:text-6xl font-extrabold text-brand-dark leading-tight mb-6"
        >
          Your Business, <span class="text-brand-primary">Digitized.</span>
        </h1>
        <p class="text-xl text-slate-600 mb-10 leading-relaxed">
          We build affordable, high-performance digital business cards and
          websites for professionals who want to cement their place in a digital
          world.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a
            href="#contact"
            class="px-8 py-4 bg-brand-primary text-white font-bold rounded-xl shadow-lg hover:shadow-brand-primary/30 transition-all"
            >Start Your Project</a
          >
          <a
            href="#services"
            class="px-8 py-4 bg-white border border-slate-200 font-bold rounded-xl hover:bg-slate-50 transition"
            >View Services</a
          >
        </div>
      </div>
    </header>

    <!-- SERVICES -->
    <section id="services" class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-brand-dark mb-4">What We Offer</h2>
          <div class="h-1 w-20 bg-brand-primary mx-auto"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <div
            class="p-8 border border-slate-100 rounded-2xl bg-slate-50 hover:border-brand-primary transition-colors group"
          >
            <div
              class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-brand-primary transition-colors"
            >
              <svg
                class="w-6 h-6 text-brand-primary group-hover:text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Web Development</h3>
            <p class="text-slate-600">
              Lightning-fast static sites built with the latest tech to ensure
              your business is always accessible.
            </p>
          </div>

          <div
            class="p-8 border border-slate-100 rounded-2xl bg-slate-50 hover:border-brand-primary transition-colors group"
          >
            <div
              class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-brand-primary transition-colors"
            >
              <svg
                class="w-6 h-6 text-brand-primary group-hover:text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Web Design</h3>
            <p class="text-slate-600">
              Clean, modern visuals tailored to your brand identity. We focus on
              conversion and user experience.
            </p>
          </div>

          <div
            class="p-8 border border-slate-100 rounded-2xl bg-slate-50 hover:border-brand-primary transition-colors group"
          >
            <div
              class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-6 group-hover:bg-brand-primary transition-colors"
            >
              <svg
                class="w-6 h-6 text-brand-primary group-hover:text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Web Hosting</h3>
            <p class="text-slate-600">
              Set it and forget it. We handle the servers, security, and updates
              while you run your business.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- STORY -->
    <section id="story" class="py-20 bg-slate-50">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-bold text-brand-dark mb-6">Our Story</h2>
            <p class="text-slate-600 mb-4">
              My name is Chris and I moved to the NL with my wife Kim and our
              daughter Sophie. Our goal in this move is to give our daughter
              more opportunities to experience culture in an environment that
              encourges community. We value safety a lot, so the Netherlands was
              a great fit for our needs.
            </p>
            <p class="text-slate-600">
              Our mission is to provide you a digital footprint in this
              increasingly digital world.
            </p>
          </div>
          <div
            class="bg-brand-dark aspect-square rounded-2xl shadow-2xl overflow-hidden"
          >
            <img
              src="images/family_photo_fixed.jpg"
              alt="Our Team"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="py-20 bg-white">
      <div class="max-w-xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-brand-dark mb-4">Work With Us</h2>
          <p class="text-slate-600">
            Ready to level up your digital presence? Send us a message.
          </p>
        </div>

        <form action="#" class="space-y-4">
          <div>
            <label class="block text-sm font-semibold mb-2">Name</label>
            <input
              type="text"
              class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition"
              placeholder="John Doe"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold mb-2">Email</label>
            <input
              type="email"
              class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition"
              placeholder="john@company.com"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold mb-2">Message</label>
            <textarea
              rows="4"
              class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition"
              placeholder="Tell us about your project..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-4 bg-brand-dark text-white font-bold rounded-lg hover:bg-brand-primary transition-all"
          >
            Send Message
          </button>
        </form>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="py-10 border-t border-slate-200 pl-24">
      <p class="text-slate-400 text-sm">© {year} AZNL Web Solutions</p>
    </footer>
  </body>
</html>
